# scheduling-api/.env
# ------------------------------------------------------------------
# SECURITY — Generate a strong secret for production:
#   python -c "import secrets; print(secrets.token_hex(64))"
# ------------------------------------------------------------------
JWT_SECRET_KEY=put-a-strong-random-secret-here
JWT_COOKIE_SECURE=False
JWT_COOKIE_SAMESITE=Lax
JWT_COOKIE_CSRF_PROTECT=False

# JWT token lifetime (in minutes)
JWT_ACCESS_EXPIRES_MIN=60

# Frontend origin for CORS (comma-separated for multiple)
# Dev: http://localhost:8080
# Production: https://yourdomain.com
FRONTEND_URL=http://localhost:8080

# ------------------------------------------------------------------
# Stripe — Subscription & Google Pay integration
# Get keys from https://dashboard.stripe.com/apikeys
# ------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_replace_with_your_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_webhook_secret
STRIPE_PRO_PRICE_ID=price_replace_with_pro_price_id
STRIPE_ENTERPRISE_PRICE_ID=price_replace_with_enterprise_price_id

# ------------------------------------------------------------------
# M-Pesa (Daraja API) — Kenya Market Integration
# Register at: https://developer.safaricom.co.ke
# ------------------------------------------------------------------
MPESA_SANDBOX=True
MPESA_CONSUMER_KEY=replace_with_daraja_consumer_key
MPESA_CONSUMER_SECRET=replace_with_daraja_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=replace_with_daraja_passkey
# Must be a public HTTPS URL — use ngrok for local dev
MPESA_CALLBACK_URL=https://yourdomain.com/mpesa/callback

# KES subscription prices
MPESA_PRO_PRICE_KES=3500
MPESA_ENTERPRISE_PRICE_KES=12000
